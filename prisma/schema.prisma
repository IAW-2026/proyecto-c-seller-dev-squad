// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Vendedor {
  id            String     @id @default(uuid())
  clerkUserId   String     @unique @map("clerk_user_id")
  nombre        String
  email         String     @unique
  descripcion   String?
  avatarUrl     String?    @map("avatar_url")
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")

  productos     Producto[]
  ventas        Venta[]

  @@map("vendedores")
}

model Producto {
  id            String          @id @default(uuid())
  nombre        String
  descripcion   String?
  precio        Decimal         @db.Decimal(10, 2)
  stock         Int             @default(0)
  marca         String?
  imagenUrl     String?         @map("imagen_url")
  activo        Boolean         @default(true)
  creadoEn      DateTime        @default(now()) @map("creado_en")
  actualizadoEn DateTime        @updatedAt @map("actualizado_en")

  vendedorId    String          @map("vendedor_id")
  vendedor      Vendedor        @relation(fields: [vendedorId], references: [id])

  talles        ProductoTalle[]
  detallesVenta DetalleVenta[]

  @@map("productos")
}

model ProductoTalle {
  id         String   @id @default(uuid())
  talle      String
  stock      Int      @default(0)
  creadoEn   DateTime @default(now()) @map("creado_en")

  productoId String   @map("producto_id")
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([productoId, talle])
  @@map("producto_talles")
}

model Venta {
  id            String       @id @default(uuid())
  ordenId       String       @unique @map("orden_id")
  paymentId     String?      @map("payment_id")   // ← agregar esto
  total         Decimal      @db.Decimal(10, 2)
  estado        EstadoVenta  @default(PENDIENTE)
  creadoEn      DateTime     @default(now()) @map("creado_en")
  actualizadoEn DateTime     @updatedAt @map("actualizado_en")

  vendedorId    String       @map("vendedor_id")
  vendedor      Vendedor     @relation(fields: [vendedorId], references: [id])
  detalles      DetalleVenta[]

  @@map("ventas")
}

enum EstadoVenta {
  PENDIENTE
  CONFIRMADO
  CANCELADO
}

model DetalleVenta {
  id             String   @id @default(uuid())
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2) @map("precio_unitario")
  talle          String?

  ventaId        String   @map("venta_id")
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  productoId     String   @map("producto_id")
  producto       Producto @relation(fields: [productoId], references: [id])

  @@map("detalles_venta")
}
